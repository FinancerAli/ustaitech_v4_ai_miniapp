# UstAiTech Bot — Environment Variables
# Copy this file to .env and fill in your values

BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=123456789
CARD_NUMBER=your_card_number
CARD_OWNER=Your Name
BOT_USERNAME=your_bot_username

# AI Agent (optional)
AI_ENABLED=false
AI_API_KEY=your_gemini_api_key
AI_MODEL=gemini-2.5-flash

# Redis (optional, for production FSM storage)
# USE_REDIS=true
# REDIS_URL=redis://localhost:6379/0

# Referral bonus tiers (optional, defaults shown)
# BONUS_JOIN_BRONZE=5000
# BONUS_JOIN_SILVER=8000
# BONUS_JOIN_GOLD=12000
# BONUS_ORDER_BRONZE=5
# BONUS_ORDER_SILVER=8
# BONUS_ORDER_GOLD=12
